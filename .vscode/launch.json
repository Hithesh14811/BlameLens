
{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "Run Semantic Git Blame",
      "type": "extensionHost",
      "request": "launch",
      "runtimeExecutable": "${execPath}",
      "args": [
        "--extensionDevelopmentPath=${workspaceFolder}",
        "--user-data-dir=${workspaceFolder}/.vscode-devhost/user-data",
        "--extensions-dir=${workspaceFolder}/.vscode-devhost/extensions"
      ],
      "outFiles": [
        "${workspaceFolder}/out/**/*.js"
      ],
      "preLaunchTask": "npm: test-compile"
    }
  ]
}
